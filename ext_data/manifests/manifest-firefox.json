{
  "name": "ZotIt",
  "version": "1.7.2",
  "description": "Zot It Anywhere",
  "manifest_version": 3,
  "action": {
    "default_icon": {
      "16": "icons/zotit_16x16.png",
      "24": "icons/zotit_24x24.png",
      "32": "icons/zotit_32x32.png",
      "48": "icons/zotit_48x48.png",
      "128": "icons/zotit_128x128.png"
    },
    "default_title": "ZotIt",
    "default_popup": "index.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://zotit.app/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "zotit@twobits.in",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "authenticationInfo",
          "personallyIdentifyingInfo"
        ]
      }
    }
  }
}